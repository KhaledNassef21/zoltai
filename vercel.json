{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "https://zoltai.org/",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "zoltai.vercel.app"
        }
      ]
    },
    {
      "source": "/:path*",
      "destination": "https://zoltai.org/:path*",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "zoltai.vercel.app"
        }
      ]
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ],
      "has": [
        {
          "type": "host",
          "value": "zoltai.org"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ],
      "has": [
        {
          "type": "host",
          "value": "zoltai.vercel.app"
        }
      ]
    }
  ]
}
